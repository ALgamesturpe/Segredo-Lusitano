Options -Indexes
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Se o pedido é para um ficheiro ou diretório que existe, servir diretamente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Redirecionar tudo o resto para index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Segurança: bloquear acesso direto a ficheiros sensíveis
<FilesMatch "\.(env|sql|log|bak|git|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear acesso à pasta includes
<IfModule mod_rewrite.c>
    RewriteRule ^includes/ - [F,L]
</IfModule>

# PHP: ocultar erros ao público
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>
